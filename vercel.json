{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "NPM_CONFIG_PRODUCTION=false npm install",
  "buildCommand": "npm run build --workspace=js-interview-client",
  "outputDirectory": "client/build",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
