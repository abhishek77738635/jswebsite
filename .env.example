# ─── Server ───────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Path from repo root (file is gitignored)
GOOGLE_APPLICATION_CREDENTIALS=server/serviceAccountKey.json

# Vercel / production: paste full service account JSON on one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

CASHFREE_CLIENT_ID=your_cashfree_client_id
CASHFREE_CLIENT_SECRET=your_cashfree_client_secret
CASHFREE_ENVIRONMENT=sandbox

# ─── API cache (reduces Firestore reads) ───────────────────────────────────
# TTL for in-memory + Redis layers (seconds)
CACHE_TTL_SECONDS=300

# Optional: Upstash Redis for shared cache across Vercel instances
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token

# Static fallback: server/data/bulk-chunks/full-bulk-interview.json when Firestore fails.
# Set on Vercel while quota is exceeded (skip Firestore reads entirely):
# USE_STATIC_DATA_ONLY=true

# Unpaid users: first N free questions (by id) are fully open; full list still shown
FREE_PREVIEW_COUNT=10

# ─── Client (must be REACT_APP_* for Create React App) ─────────────────────
# Local + production: always use deployed API (not localhost)
REACT_APP_API_URL=https://jswebsite-server.vercel.app/api

REACT_APP_FIREBASE_API_KEY=your_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id
REACT_APP_FIREBASE_MEASUREMENT_ID=your_measurement_id

REACT_APP_CASHFREE_ENV=sandbox
