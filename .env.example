# ─── Server ───────────────────────────────────────────────────────────────
# Use 5100 locally if another old API is still bound to 5000
PORT=5100
NODE_ENV=development

# Path from repo root (file is gitignored)
GOOGLE_APPLICATION_CREDENTIALS=server/serviceAccountKey.json

# Vercel / production: paste full service account JSON on one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Local: sandbox (api reachable). Deploy (Render/Vercel): production.
# Many laptops cannot reach api.cashfree.com — you will see "Connect Timeout" in the server log.
CASHFREE_ENVIRONMENT=sandbox

# Option A — one pair (simplest)
# CASHFREE_CLIENT_ID=your_sandbox_or_prod_client_id
# CASHFREE_CLIENT_SECRET=your_secret

# Option B — both pairs; flip only CASHFREE_ENVIRONMENT
CASHFREE_SANDBOX_CLIENT_ID=your_sandbox_app_id
CASHFREE_SANDBOX_CLIENT_SECRET=cfsk_ma_test_...
CASHFREE_PRODUCTION_CLIENT_ID=your_production_app_id
CASHFREE_PRODUCTION_CLIENT_SECRET=cfsk_ma_prod_...

# Premium one-time price (INR) — server charge amount and client copy
PREMIUM_PRICE_INR=10
# REACT_APP_PREMIUM_PRICE_INR=10

# ─── API cache (reduces Firestore reads) ───────────────────────────────────
# TTL for in-memory + Redis layers (seconds)
CACHE_TTL_SECONDS=300

# Optional: Upstash Redis for shared cache across Vercel instances
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token

# Static fallback: server/data/bulk-chunks/full-bulk-interview.json when Firestore fails.
# Set on Vercel while quota is exceeded (skip Firestore reads entirely):
# USE_STATIC_DATA_ONLY=true

# Unpaid users: share of questions fully open (stable random spread, not first-N-by-id)
FREE_PERCENT=0.25
# FREE_ASSIGNMENT_SEED=upchallenges-v1

# Local payment testing: comment out REACT_APP_API_URL so the client proxies to localhost:5100
# Local dev
FRONTEND_URL=http://localhost:5001
# Vercel API project env (required for production Cashfree return_url):
# FRONTEND_URL=https://jswebsite-client.vercel.app

# ─── Client (must be REACT_APP_* for Create React App) ─────────────────────
# Production deployed API — only set when you want the client to hit remote API:
# REACT_APP_API_URL=https://jswebsite-server.vercel.app/api

REACT_APP_FIREBASE_API_KEY=your_api_key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
REACT_APP_FIREBASE_APP_ID=your_app_id
REACT_APP_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Optional fallback only — checkout mode comes from API (create-order). Set production on server first.
# REACT_APP_CASHFREE_ENV=production
